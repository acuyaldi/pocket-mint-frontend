# ── Pocket Mint frontend environment ────────────────────────────────────────
# Copy to .env.local and fill in. All frontend vars are NEXT_PUBLIC_* (exposed to
# the browser) — never put a server-only secret or service-role key here.

# Supabase — public client config (safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Backend API base URL. Backend is JWT-only: the frontend attaches
# `Authorization: Bearer <supabase access token>` to every protected request.
# There is NO backend API key — do not add one.
NEXT_PUBLIC_API_URL=http://localhost:5001/api/v1

# hCaptcha public site key
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=your-hcaptcha-site-key

E2E_EMAIL=""
E2E_PASSWORD=""