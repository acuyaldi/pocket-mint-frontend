{
  "name": "pocket-mint",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev -p 4000",
    "build": "next build",
    "clean": "node -e \"fs.rmSync('.next',{recursive:true,force:true})\"",
    "start": "next build && next start -p 4000",
    "start:fresh": "npm run clean && next build && next start -p 4000",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "screenshot:authenticated": "node --env-file=.env scripts/capture-authenticated-pages.mjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.1",
    "@tanstack/react-query": "^5.101.0",
    "axios": "^1.17.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.18.0",
    "next": "16.2.9",
    "next-intl": "^4.13.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.5.3",
    "@storybook/addon-docs": "^10.5.3",
    "@storybook/addon-vitest": "^10.5.3",
    "@storybook/nextjs-vite": "^10.5.3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/browser-playwright": "4.1.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "eslint-plugin-storybook": "^10.5.3",
    "playwright": "^1.61.1",
    "storybook": "^10.5.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
