// Types
type WalletCategory = "asset" | "debt";
type WalletKind = "cash" | "bank" | "e_wallet" | "credit_card" | "paylater";

// New type for asset sub-categories
type AssetSubType = "bank_account" | "e_wallet" | "cash_on_hand" | "piutang";

// New type for debt sub-categories
type DebtSubType = "credit_card" | "paylater" | "utang_personal" | "line_of_credit";

interface WalletBase {
  id: string;
  name: string;
  category: WalletCategory;
  kind: WalletKind;
  balance: number;
  icon: "landmark" | "creditcard" | "coins" | "smartphone" | "bitcoin" | "wallet" | "banknote" | "handshake";
  sparklineData?: number[];
}

interface AssetWallet extends WalletBase {
  category: "asset";
}

interface DebtWallet extends WalletBase {
  category: "debt";
  creditLimit: number;
  outstanding: number;
}

type WalletItem = AssetWallet | DebtWallet;

// Helpers
function formatRp(amount: number): string {
  return new Intl.NumberFormat("id-ID", {
    style: "currency",
    currency: "IDR",
    minimumFractionDigits: 0,
    maximumFractionDigits: 0,
  }).format(Math.round(amount));
}

