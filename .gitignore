# === DEPENDENCIES ===
# Mengabaikan node_modules di frontend, backend, maupun root
**/node_modules/
.pnpm-store/

# === NEXT.JS PRODUCTION BUILD ===
# Mengabaikan hasil build frontend Next.js
**/ .next/
**/out/

# === ENV / SENSITIVE DATA ===
# Mengabaikan file rahasia/token database agar tidak bocor ke GitHub
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
**/.env
**/.env*.local

# === SYSTEM FILES ===
# Mengabaikan file bawaan OS yang tidak penting
.DS_Store
Thumbs.db

# IDE‑generated cache files
*.sst
*.meta

# Next.js build artefacts – never commit
/apps/frontend/.next/
/apps/frontend/.next/**

# (optionally) ignore other generated caches
/apps/frontend/.next/dev/**

# You can also ignore the whole folder generically:
# **/.next/